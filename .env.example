# ============================================================================
# SUPABASE — https://supabase.com/dashboard/project/_/settings/api
# ============================================================================

# Project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Anon / public key — es segura para el cliente, RLS la protege
# (Settings → API → Project API keys → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SOLO server-side, nunca con prefijo NEXT_PUBLIC_
# (Settings → API → Project API keys → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# APP
# ============================================================================

# URL base del sitio. Cambiar por ambiente:
#   Local:      http://localhost:3000
#   Producción: https://<tu-proyecto>.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
